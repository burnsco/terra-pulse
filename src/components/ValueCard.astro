---
interface Props {
  icon: 'sun' | 'wind' | 'leaf';
  label: string;
  detail: string;
}

const { icon, label, detail } = Astro.props;
---
<div class="group relative overflow-hidden rounded-2xl border border-[#4ade80]/10 bg-gradient-to-b from-[#1a241a] to-[#0f1410] p-8 text-center transition-all duration-300 hover:-translate-y-2 hover:border-[#4ade80]/30 hover:shadow-[0_10px_40px_-10px_rgba(74,222,128,0.15)] animate-fade-in-up">
  <div class="absolute -right-10 -top-10 h-32 w-32 rounded-full bg-[#4ade80]/5 blur-3xl transition-all duration-500 group-hover:bg-[#4ade80]/10"></div>
  <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-[#4ade80]/10 text-[#4ade80] transition-transform duration-300 group-hover:scale-110 group-hover:bg-[#4ade80]/20">
    {icon === 'sun' && (
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
      </svg>
    )}
    {icon === 'wind' && (
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4.5 9.75h15M4.5 14.25h9m-9 0l2.25-2.25M13.5 14.25l2.25-2.25M18.75 9.75l-2.25 2.25M18.75 14.25l2.25-2.25" />
      </svg>
    )}
    {icon === 'leaf' && (
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
      </svg>
    )}
  </div>
  <h3 class="relative mt-6 font-bold uppercase tracking-wider text-[#e8f0e6] group-hover:text-[#4ade80] transition-colors">{label}</h3>
  <p class="relative mt-2 text-sm text-[#9ca89a] leading-relaxed">{detail}</p>
</div>
