---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contact – Terra Pulse" description="Get in touch with Terra Pulse. General inquiries, partnerships, or support.">
  <a href="#main" class="sr-only sr-only-focusable">Skip to content</a>
  <div class="min-h-screen flex flex-col relative overflow-hidden">
    <!-- Subtle background effect -->
    <div class="absolute right-1/4 top-0 -z-10 h-[600px] w-[600px] rounded-full bg-[#4ade80]/5 blur-[120px] pointer-events-none"></div>

    <div class="mx-auto w-full max-w-6xl flex-1 px-6 py-8 md:px-10 relative z-10">
      <Nav />

      <main id="main">
        <header class="mt-20 text-center animate-fade-in-up">
          <p class="inline-flex items-center gap-2 rounded-full border border-[#4ade80]/20 bg-[#4ade80]/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-[#4ade80]">Contact</p>
          <h1 class="mt-6 text-4xl font-extrabold tracking-tight md:text-6xl">
            Let's <span class="bg-gradient-to-r from-[#4ade80] to-[#22c55e] bg-clip-text text-transparent">connect.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-xl text-[#9ca89a] text-lg font-light leading-relaxed">
            Whether you want to fund restoration, offset carbon, or explore a partnership, we're here.
          </p>
        </header>

        <section class="mx-auto mt-20 max-w-xl animate-fade-in-up delay-100" aria-labelledby="contact-heading">
          <h2 id="contact-heading" class="sr-only">Contact form and details</h2>

          <div class="relative rounded-3xl border border-[#4ade80]/20 bg-[#161c14]/80 backdrop-blur-md p-8 shadow-2xl overflow-hidden glass">
            <div class="absolute -right-20 -top-20 h-40 w-40 rounded-full bg-[#4ade80]/10 blur-3xl"></div>
            
            <form class="relative z-10 space-y-6" action="#" method="post">
              <div>
                <label for="name" class="block text-sm font-medium text-[#e8f0e6] mb-2">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full rounded-xl border border-[#4ade80]/20 bg-[#0f1410]/50 px-4 py-3.5 text-[#e8f0e6] placeholder-[#9ca89a]/50 backdrop-blur-sm transition-all focus:border-[#4ade80] focus:outline-none focus:ring-2 focus:ring-[#4ade80]/50"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-[#e8f0e6] mb-2">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full rounded-xl border border-[#4ade80]/20 bg-[#0f1410]/50 px-4 py-3.5 text-[#e8f0e6] placeholder-[#9ca89a]/50 backdrop-blur-sm transition-all focus:border-[#4ade80] focus:outline-none focus:ring-2 focus:ring-[#4ade80]/50"
                  placeholder="you@example.com"
                />
              </div>
              <div>
                <label for="interest" class="block text-sm font-medium text-[#e8f0e6] mb-2">I'm interested in</label>
                <select
                  id="interest"
                  name="interest"
                  class="w-full rounded-xl border border-[#4ade80]/20 bg-[#0f1410]/90 px-4 py-3.5 text-[#e8f0e6] backdrop-blur-sm transition-all focus:border-[#4ade80] focus:outline-none focus:ring-2 focus:ring-[#4ade80]/50"
                >
                  <option value="">Select project...</option>
                  <option value="restore-fund">Restore Fund</option>
                  <option value="offset">Carbon offset</option>
                  <option value="partner">Partnership</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-[#e8f0e6] mb-2">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  class="w-full rounded-xl border border-[#4ade80]/20 bg-[#0f1410]/50 px-4 py-3.5 text-[#e8f0e6] placeholder-[#9ca89a]/50 backdrop-blur-sm transition-all focus:border-[#4ade80] focus:outline-none focus:ring-2 focus:ring-[#4ade80]/50"
                  placeholder="How can we help?"
                />
              </div>
              <button
                type="submit"
                class="mt-2 w-full rounded-full bg-gradient-to-r from-[#4ade80] to-[#22c55e] py-4 text-sm font-bold uppercase tracking-[0.15em] text-[#0f1410] shadow-[0_0_15px_rgba(74,222,128,0.3)] transition-all hover:scale-[1.02] hover:shadow-[0_0_25px_rgba(74,222,128,0.5)]"
              >
                Send message
              </button>
            </form>
          </div>

          <div class="mt-12 text-center text-sm text-[#9ca89a] animate-fade-in-up delay-200">
            <p>General inquiries: <a href="mailto:hello@terrapulse.org" class="font-medium text-[#4ade80] transition-colors hover:text-[#22c55e] hover:underline">hello@terrapulse.org</a></p>
            <p class="mt-2">Partnerships: <a href="mailto:partners@terrapulse.org" class="font-medium text-[#4ade80] transition-colors hover:text-[#22c55e] hover:underline">partners@terrapulse.org</a></p>
          </div>
        </section>
      </main>
    </div>
    <Footer />
  </div>
</BaseLayout>
