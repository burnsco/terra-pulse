---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const projects = [
  {
    name: 'Pacific Northwest Corridor',
    region: 'Oregon & Washington',
    hectares: 620,
    focus: 'Reforestation, riparian buffer',
    img: 'https://images.unsplash.com/photo-1511497584788-876760111969?auto=format&fit=crop&w=800&q=80',
    status: 'Active',
  },
  {
    name: 'Great Lakes Wetlands',
    region: 'Michigan',
    hectares: 410,
    focus: 'Wetland restoration, native species',
    img: 'https://images.unsplash.com/photo-1473341304170-971dccb5ac1e?auto=format&fit=crop&w=800&q=80',
    status: 'Active',
  },
  {
    name: 'Sonoran Desert Recharge',
    region: 'Arizona',
    hectares: 280,
    focus: 'Desert riparian, groundwater recharge',
    img: 'https://images.unsplash.com/photo-1509316785289-025f5b846b35?auto=format&fit=crop&w=800&q=80',
    status: 'Active',
  },
  {
    name: 'Southeast Longleaf',
    region: 'Georgia & South Carolina',
    hectares: 540,
    focus: 'Longleaf pine restoration, prescribed fire',
    img: 'https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&w=800&q=80',
    status: 'Active',
  },
  {
    name: 'Northern Prairie Grasslands',
    region: 'Montana',
    hectares: 390,
    focus: 'Grassland restoration, bison habitat',
    img: 'https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&w=800&q=80',
    status: 'Planning',
  },
  {
    name: 'Appalachian Streams',
    region: 'West Virginia',
    hectares: 220,
    focus: 'Stream restoration, acid mine remediation',
    img: 'https://images.unsplash.com/photo-1472214103451-9374bd1c798e?auto=format&fit=crop&w=800&q=80',
    status: 'Active',
  },
];
---

<BaseLayout title="Projects – Terra Pulse" description="Explore Terra Pulse restoration projects across 12 regions. Reforestation, wetlands, grasslands, and more.">
  <a href="#main" class="sr-only sr-only-focusable">Skip to content</a>
  <div class="min-h-screen flex flex-col relative overflow-hidden">
    <!-- Subtle background effect -->
    <div class="absolute inset-x-0 top-0 -z-10 h-[800px] w-full bg-gradient-to-b from-[#4ade80]/5 to-transparent pointer-events-none"></div>

    <div class="mx-auto w-full max-w-6xl flex-1 px-6 py-8 md:px-10 relative z-10">
      <Nav />

      <main id="main">
        <header class="mt-20 text-center animate-fade-in-up">
          <p class="inline-flex items-center gap-2 rounded-full border border-[#4ade80]/20 bg-[#4ade80]/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-[#4ade80]">Explore projects</p>
          <h1 class="mt-6 text-4xl font-extrabold tracking-tight md:text-6xl">
            Where we <span class="bg-gradient-to-r from-[#4ade80] to-[#22c55e] bg-clip-text text-transparent">work.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-xl text-[#9ca89a] text-lg font-light leading-relaxed">
            2,847 hectares across 12 partner regions. Each project is third-party verified and reported annually.
          </p>
        </header>

        <section class="mt-24 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3 animate-fade-in-up delay-100" aria-labelledby="projects-heading">
          <h2 id="projects-heading" class="sr-only">Restoration projects</h2>
          {projects.map((p) => (
            <article class="group overflow-hidden rounded-3xl border border-[#4ade80]/10 bg-[#161c14]/80 backdrop-blur-sm transition-all duration-300 hover:-translate-y-2 hover:border-[#4ade80]/40 hover:shadow-[0_15px_40px_-15px_rgba(74,222,128,0.2)] glass">
              <div class="relative overflow-hidden h-52">
                <div class="absolute inset-0 bg-black/10 z-10 group-hover:bg-transparent transition-colors duration-300"></div>
                <img
                  src={p.img}
                  alt=""
                  width="800"
                  height="400"
                  class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                  loading="lazy"
                />
              </div>
              <div class="p-6">
                <div class="flex items-start justify-between gap-4">
                  <h3 class="font-bold text-[#e8f0e6] text-lg leading-tight group-hover:text-[#4ade80] transition-colors">{p.name}</h3>
                  <span class="inline-flex items-center whitespace-nowrap rounded-full border border-[#4ade80]/30 bg-[#4ade80]/10 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-[#4ade80]">
                    {p.status}
                  </span>
                </div>
                <div class="mt-4 flex items-center gap-2 text-sm text-[#4ade80]">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  {p.region}
                </div>
                <p class="mt-3 text-sm text-[#9ca89a] leading-relaxed">{p.focus}</p>
                
                <div class="mt-6 pt-4 border-t border-[#4ade80]/10 flex items-center justify-between">
                  <span class="text-xs font-bold uppercase tracking-wider text-[#e8f0e6]">{p.hectares} <span class="text-[#9ca89a]">ha restored</span></span>
                  <a href="#" class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-[#4ade80]/10 text-[#4ade80] transition-colors group-hover:bg-[#4ade80] group-hover:text-[#0f1410]" aria-label={`View details for ${p.name}`}>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </section>
      </main>
    </div>
    <Footer />
  </div>
</BaseLayout>
